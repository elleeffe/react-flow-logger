{
	"name": "react-flow-logger",
	"version": "1.0.0",
	"description": "Runtime flow logger for React (dev only)",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "concurrently \"pnpm run dev:lib\" \"tsx server/index.ts\" \"pnpm --dir dashboard dev\" \"pnpm --dir example-app dev\"",
		"dev:lib": "tsc --watch",
		"build:lib": "tsc",
		"build:server": "tsc -p tsconfig.server.json",
		"build:dashboard": "pnpm --dir dashboard run build && rm -rf dist/dashboard && mv dashboard/dist dist/dashboard",
		"build": "rm -rf dist && pnpm run build:lib && pnpm run build:server && pnpm run build:dashboard",
		"example": "pnpm --dir example-app dev",
		"dashboard": "npx react-flow-logger",
		"prepare": "pnpm run build",
		"lint": "biome check",
		"format": "biome format"
	},
	"bin": {
		"react-flow-logger": "dist/cli.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/elleeffe/react-flow-logger.git"
	},
	"keywords": [
		"react",
		"logger",
		"devtools"
	],
	"author": "TUO_NOME",
	"license": "MIT",
	"type": "module",
	"bugs": {
		"url": "https://github.com/elleeffe/react-flow-logger/issues"
	},
	"homepage": "https://github.com/elleeffe/react-flow-logger#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/express": "^5.0.6",
		"@types/node": "^25.3.2",
		"@types/react": "^19.2.14",
		"@types/ws": "^8.18.1",
		"concurrently": "^9.2.1",
		"react": "^19.2.4",
		"tsx": "^4.21.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"express": "^5.2.1",
		"ws": "^8.19.0"
	}
}
